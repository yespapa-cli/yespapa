{
  "name": "yespapa",
  "version": "0.1.0",
  "description": "TOTP-authenticated command gateway — intercept dangerous shell commands, require human approval",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "yespapa": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "totp",
    "security",
    "cli",
    "shell",
    "command-gateway",
    "agent-safety",
    "llm",
    "approval"
  ],
  "author": "YesPaPa Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yespapa-cli/yespapa.git"
  },
  "homepage": "https://github.com/yespapa-cli/yespapa#readme",
  "bugs": {
    "url": "https://github.com/yespapa-cli/yespapa/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.12",
    "@types/qrcode": "^1.5.5",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
